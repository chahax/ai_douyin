# Application Settings
APP_NAME=WisdomAI
APP_VERSION=0.1.0
DEBUG=True
LOG_LEVEL=INFO

# AI Providers
# LLM provider: mock | openai_compatible | ollama
LLM_PROVIDER=mock

# To use local Ollama as the main provider, switch to:
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# DeepSeek / OpenAI Compatible API
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=120

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# Database (Default to SQLite for MVP)
DATABASE_URL=sqlite:///./data/wisdom_ai.db

# Redis (Optional for MVP, can be mocked)
REDIS_URL=redis://localhost:6379/0

# Platform APIs (Douyin)
DOUYIN_CLIENT_KEY=your_client_key
DOUYIN_CLIENT_SECRET=your_client_secret
DOUYIN_HOME_URL=https://www.douyin.com/
DOUYIN_CREATOR_BASE_URL=https://creator.douyin.com
DOUYIN_UPLOAD_URL=https://creator.douyin.com/creator-micro/content/upload
DOUYIN_STORAGE_STATE_PATH=./data/browser/douyin/storage_state.json
DOUYIN_USER_DATA_DIR=./data/browser/douyin/user_data
BROWSER_CHANNEL=
BROWSER_HEADLESS=false
BROWSER_SLOW_MO_MS=0
BROWSER_TIMEOUT_MS=30000

# Account login email verification
# 163 SMTP uses an authorization code, not the mailbox password.
# If you use port 25, keep SMTP_USE_SSL=false. If you use port 465, set SMTP_USE_SSL=true.
SMTP_HOST=smtp.163.com
SMTP_PORT=25
SMTP_USERNAME=your_163_email@163.com
SMTP_PASSWORD=your_163_smtp_authorization_code
SMTP_FROM=your_163_email@163.com
SMTP_USE_SSL=false
LOGIN_CODE_TTL_MINUTES=10
LOGIN_CODE_COOLDOWN_SECONDS=60

# Storage
STORAGE_ROOT=./data
BOOKS_DIR=./data/books
EXTRACTED_DIR=./data/extracted
VIDEOS_DIR=./data/videos
REF_AUDIO_DIR=./data/ref_audio
CHROMA_PERSIST_DIR=./data/chroma_db
DEFAULT_BGM_PATH=./data/ref_audio/Morning-Routine-Lofi-Study-Music(chosic.com).mp3
TTS_PROVIDER=gpt_sovits

# GPT-SoVITS
GPT_SOVITS_API_URL=http://127.0.0.1:9880
GPT_SOVITS_SDK_ROOT=./GPT_SoVITS
GPT_SOVITS_USE_SDK=true
GPT_SOVITS_ENABLE_HTTP_FALLBACK=false
GPT_SOVITS_DEFAULT_REF_AUDIO=./data/ref_audio/mature_male_ref.wav
GPT_SOVITS_DEFAULT_REF_TEXT=是的，爱和混乱有时候会同时到来，但人最终要学会让自己重新稳定下来。

# ComfyUI background generation
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8190
COMFYUI_MAIN_PATH=D:/IT/AI_vido/ComfyUI/main.py
COMFYUI_CHECKPOINT=flux1-schnell-fp8.safetensors
COMFYUI_STEPS=4
COMFYUI_CFG=1.0
ENABLE_BACKGROUND_SCENE_PLANNER=false
BACKGROUND_SCENE_LIBRARY_DIR=data/background_scene_library
BACKGROUND_SCENE_PLANNER_USE_LLM=false
BACKGROUND_SCENE_ANALYSIS_MODEL=
